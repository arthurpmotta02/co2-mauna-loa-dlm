#| label: tabela-previsoes
#| code-summary: "PrevisĂµes selecionadas â€” quatro modelos"
meses_pt <- c("Janeiro","Fevereiro","MarĂ§o","Abril","Maio","Junho",
"Julho","Agosto","Setembro","Outubro","Novembro","Dezembro")
# Renomear modelos para labels curtos na tabela
prev_tab <- prev_all |>
mutate(
Ano   = as.integer(floor(tempo)),
Mes   = meses_pt[as.integer(round((tempo - floor(tempo)) * 12)) + 1L],
mod_s = recode(modelo,
"A â€” dlmModSeas"          = "Mod. A",
