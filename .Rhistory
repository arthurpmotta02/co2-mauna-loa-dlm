beta  = suav_A_obj$s[2:(n+1), 2] * 12,
lo    = suav_A_obj$s[2:(n+1), 2] * 12 - 1.96 * sd_sA * 12,
hi    = suav_A_obj$s[2:(n+1), 2] * 12 + 1.96 * sd_sA * 12
)
# Modelo C: slope = estado 2 do SSMtrend
sd_beta_C <- sqrt(pmax(as.numeric(kfas_full$V[2, 2, ]), 0))
beta_C <- tibble(
tempo = tempo_vec,
beta  = as.numeric(kfas_full$alphahat[, 2]) * 12,
lo    = as.numeric(kfas_full$alphahat[, 2]) * 12 - 1.96 * sd_beta_C * 12,
hi    = as.numeric(kfas_full$alphahat[, 2]) * 12 + 1.96 * sd_beta_C * 12
)
make_beta_plot <- function(df, titulo, cor) {
df |> ggplot(aes(x = tempo)) +
geom_ribbon(aes(ymin = lo, ymax = hi), fill = cor, alpha = 0.20) +
geom_line(aes(y = beta), color = cor, linewidth = 0.9) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50") +
scale_x_continuous(breaks = seq(1960, 1997, by = 5)) +
labs(title = titulo, x = NULL, y = "ppm/ano")
}
make_beta_plot(beta_A, expression(hat(beta)[t] ~ "â€” Modelo A"), cores[2]) /
make_beta_plot(beta_B, expression(hat(beta)[t] ~ "â€” Modelo B"), cores[3]) /
make_beta_plot(beta_C, expression(hat(beta)[t] ~ "â€” Modelo C"), cores[5])
#| label: desconto-impl
#| code-summary: "ImplementaĂ§ĂŁo do MLD com fatores de desconto e V desconhecido"
mld_desconto <- function(y, mod, delta_T = 0.95, delta_S = 0.98,
m0, C0_star, n0 = 1, S0) {
n  <- length(y)
p  <- length(m0)
# Extrair G e F robustamente (dlm armazena como matriz ou lista)
G    <- if (is.list(mod$GG)) mod$GG[[1]] else mod$GG
Fvec <- matrix(if (is.list(mod$FF)) mod$FF[[1]] else mod$FF, ncol = 1)
# Garantir dimensĂµes corretas
stopifnot(nrow(G) == p, ncol(G) == p, nrow(Fvec) == p)
idx_T <- 1:2   # tendĂŞncia
idx_S <- 3:p   # sazonal (funciona para qualquer p)
m <- m0;  C <- C0_star;  nv <- n0;  S <- S0
mt <- matrix(NA, n, p);  Ct <- array(NA, c(p, p, n))
at <- matrix(NA, n, p);  Rt <- array(NA, c(p, p, n))
ft <- numeric(n);  Qt <- numeric(n);  et <- numeric(n)
nt <- numeric(n);  St <- numeric(n)
for (t in seq_len(n)) {
a  <- as.numeric(G %*% m)
P  <- G %*% C %*% t(G)
R  <- P
R[idx_T, idx_T] <- P[idx_T, idx_T] / delta_T
R[idx_S, idx_S] <- P[idx_S, idx_S] / delta_S
R[idx_T, idx_S] <- P[idx_T, idx_S] / sqrt(delta_T * delta_S)
R[idx_S, idx_T] <- P[idx_S, idx_T] / sqrt(delta_T * delta_S)
f  <- as.numeric(t(Fvec) %*% a)
Qs <- as.numeric(t(Fvec) %*% R %*% Fvec) + 1
e  <- y[t] - f
nv_new <- nv + 1
S_new  <- S * (1 + (e^2 / (Qs * S) - 1) / nv_new)
A <- R %*% Fvec / Qs
m <- a + as.numeric(A) * e
C <- (S_new / S) * (R - tcrossprod(A) * Qs)
nv <- nv_new;  S <- S_new
mt[t, ] <- m;  Ct[, , t] <- C;  at[t, ] <- a;  Rt[, , t] <- R
ft[t] <- f;  Qt[t] <- Qs;  et[t] <- e;  nt[t] <- nv;  St[t] <- S
}
list(mt = mt, Ct = Ct, at = at, Rt = Rt,
ft = ft, Qt = Qt, et = et, nt = nt, St = St,
G = G, F = Fvec)
}
# SuavizaĂ§ĂŁo backward
suavizar_desconto <- function(filt_res) {
n  <- nrow(filt_res$mt)
p  <- ncol(filt_res$mt)
G  <- filt_res$G
ms <- matrix(NA, n, p)
Cs <- array(NA, c(p, p, n))
ms[n, ]    <- filt_res$mt[n, ]
Cs[, , n]  <- filt_res$Ct[, , n]
for (t in (n - 1):1) {
Rinv    <- solve(filt_res$Rt[, , t + 1])
Ht      <- filt_res$Ct[, , t] %*% t(G) %*% Rinv
ms[t, ] <- filt_res$mt[t, ] +
Ht %*% (ms[t + 1, ] - filt_res$at[t + 1, ])
Cs[, , t] <- filt_res$Ct[, , t] -
Ht %*% (filt_res$Rt[, , t + 1] - Cs[, , t + 1]) %*% t(Ht)
# Garantir simetria e positividade diagonal
Cs[, , t] <- (Cs[, , t] + t(Cs[, , t])) / 2
}
list(ms = ms, Cs = Cs)
}
#| label: desconto-ajuste
#| code-summary: "Ajuste do modelo com fatores de desconto Î´_T = 0.95, Î´_S = 0.98"
# DimensĂŁo real do vetor de estados do Modelo B
# dlmModTrig(s=12, q=6): o harmĂ´nico de Nyquist (j=6) tem apenas 1 estado,
# entĂŁo dim = 2 (tend) + 2*J - 1 (trig) = 13, nĂŁo 14
p_B <- nrow(mld_B$GG)   # dimensĂŁo real extraĂ­da do modelo
# CondiĂ§Ăµes iniciais com dimensĂŁo correta
m0_desc <- c(315, 0.1, rep(0, p_B - 2))
C0_star  <- diag(c(100, 1, rep(25, p_B - 2)))
# S0: estimativa inicial de V
S0_init <- var(as.numeric(co2)[1:24])
delta_T <- 0.95
delta_S <- 0.98
filt_desc <- mld_desconto(
y       = as.numeric(co2),
mod     = mld_B,
delta_T = delta_T,
delta_S = delta_S,
m0      = m0_desc,
C0_star = C0_star,
n0      = 1,
S0      = S0_init
)
suav_desc <- suavizar_desconto(filt_desc)
# ICs: Var(Î¸_t | D_t) = S_t * C*_t  â†’  sd = sqrt(S_t * C*_t[1,1])
# Para filtragem: usar S_t de cada instante
sd_filt_d <- sqrt(pmax(
sapply(1:n, function(t) filt_desc$St[t] * filt_desc$Ct[1, 1, t]), 0))
# Para suavizaĂ§ĂŁo: usar S_n (toda a informaĂ§ĂŁo)
Sn <- tail(filt_desc$St, 1)
sd_suav_d <- sqrt(pmax(
sapply(1:n, function(t) Sn * suav_desc$Cs[1, 1, t]), 0))
ic_mult_filt <- qt(0.975, df = filt_desc$nt)
ic_mult_suav <- qt(0.975, df = filt_desc$nt[n])
res_desc_df <- tibble(
tempo      = tempo_vec,
obs        = as.numeric(co2),
niv_filt   = filt_desc$mt[, 1],
lo_filt    = filt_desc$mt[, 1] - ic_mult_filt * sd_filt_d,
hi_filt    = filt_desc$mt[, 1] + ic_mult_filt * sd_filt_d,
niv_suav   = suav_desc$ms[, 1],
lo_suav    = suav_desc$ms[, 1] - ic_mult_suav * sd_suav_d,
hi_suav    = suav_desc$ms[, 1] + ic_mult_suav * sd_suav_d,
St_val     = filt_desc$St     # renomeado para evitar conflito com V_est global
)
cat(sprintf("Î´_T = %.2f | Î´_S = %.2f\n", delta_T, delta_S))
cat(sprintf("V estimado (S_n) = %.5f\n", tail(filt_desc$St, 1)))
#| label: plot-desconto-filt
#| fig-cap: "Filtragem com fatores de desconto ($\\delta_T = 0{,}95$, $\\delta_S = 0{,}98$) e $V$ desconhecido. Os ICs sĂŁo baseados na distribuiĂ§ĂŁo $T_{n_t}$ e alargam-se no inĂ­cio da sĂ©rie (menor $n_t$), estreitando Ă  medida que $S_t$ converge."
#| fig-height: 5
ggplot(res_desc_df, aes(x = tempo)) +
geom_ribbon(aes(ymin = lo_filt, ymax = hi_filt),
fill = cores[2], alpha = 0.20) +
geom_line(aes(y = obs), color = cores[1],
linewidth = 0.5, alpha = 0.7) +
geom_line(aes(y = niv_filt), color = cores[2],
linewidth = 0.9) +
scale_x_continuous(breaks = seq(1960, 1997, by = 5)) +
scale_y_continuous(labels = label_number(suffix = " ppm")) +
labs(
title    = expression("Filtragem com Fatores de Desconto â€” NĂ­vel" ~ mu[t]),
subtitle = bquote(delta[T] == .(delta_T) ~ "|" ~ delta[S] == .(delta_S) ~
"| V desconhecido (distribuiĂ§ĂŁo" ~ t[n[t]] * ")"),
x        = NULL,
y        = expression(CO[2] ~ "(ppm)")
)
#| label: plot-desconto-suav
#| fig-cap: "SuavizaĂ§ĂŁo com fatores de desconto. ICs baseados em $T_{n_n}$ com $n_n = n$."
#| fig-height: 5
ggplot(res_desc_df, aes(x = tempo)) +
geom_ribbon(aes(ymin = lo_suav, ymax = hi_suav),
fill = cores[3], alpha = 0.20) +
geom_line(aes(y = obs), color = cores[1],
linewidth = 0.5, alpha = 0.7) +
geom_line(aes(y = niv_suav), color = cores[3],
linewidth = 0.9) +
scale_x_continuous(breaks = seq(1960, 1997, by = 5)) +
scale_y_continuous(labels = label_number(suffix = " ppm")) +
labs(
title    = expression("SuavizaĂ§ĂŁo com Fatores de Desconto â€” NĂ­vel" ~ mu[t]),
subtitle = bquote(delta[T] == .(delta_T) ~ "|" ~ delta[S] == .(delta_S) ~
"| IC 95% baseado em" ~ T[n[t]]),
x        = NULL,
y        = expression(CO[2] ~ "(ppm)")
)
#| label: plot-V-estimado
#| fig-cap: "EvoluĂ§ĂŁo de $S_t$ ao longo do tempo â€” estimativa sequencial da variĂ˘ncia observacional $V$. $S_t$ parte do valor inicial $S_0$ e converge progressivamente Ă  medida que mais observaĂ§Ăµes sĂŁo incorporadas."
#| fig-height: 4
Sn_val <- tail(filt_desc$St, 1)
res_desc_df |>
ggplot(aes(x = tempo, y = St_val)) +
geom_line(color = cores[5], linewidth = 0.9) +
geom_hline(yintercept = Sn_val, linetype = "dashed",
color = cores[2], linewidth = 0.7) +
annotate("text", x = 1970, y = Sn_val * 1.3,
label = sprintf("S[n] = %.5f (convergido)", Sn_val),
color = cores[2], size = 3.5) +
scale_x_continuous(breaks = seq(1960, 1997, by = 5)) +
labs(
title    = expression("Estimativa Sequencial de" ~ V ~ "via Fator de Desconto"),
subtitle = expression(S[t] ~ "converge Ă  medida que mais observaĂ§Ăµes sĂŁo incorporadas"),
x        = NULL,
y        = expression(S[t])
)
#| label: previsao-todos
#| include: false
h      <- 24
t_prev <- seq(fim[1] + fim[2] / 12, by = 1/12, length.out = h)
# Modelo B (principal)
prev_B  <- dlmForecast(filt, nAhead = h)
sd_B    <- sqrt(unlist(prev_B$Q))
prev_df <- tibble(
tempo = t_prev, modelo = "B â€” dlmModTrig",
central = as.numeric(prev_B$f),
lo95    = as.numeric(prev_B$f) - 1.96 * sd_B,
hi95    = as.numeric(prev_B$f) + 1.96 * sd_B
)
# Modelo A
prev_A  <- dlmForecast(filt_A_obj, nAhead = h)
sd_A    <- sqrt(unlist(prev_A$Q))
prev_A_df <- tibble(
tempo = t_prev, modelo = "A â€” dlmModSeas",
central = as.numeric(prev_A$f),
lo95    = as.numeric(prev_A$f) - 1.96 * sd_A,
hi95    = as.numeric(prev_A$f) + 1.96 * sd_A
)
# Modelo C (KFAS)
prev_C_obj <- predict(mld_C, n.ahead = h, interval = "confidence", level = 0.95)
prev_C_df  <- tibble(
tempo = t_prev, modelo = "C â€” KFAS",
central = as.numeric(prev_C_obj[, "fit"]),
lo95    = as.numeric(prev_C_obj[, "lwr"]),
hi95    = as.numeric(prev_C_obj[, "upr"])
)
# SARIMA do Trabalho 1
fit_sarima <- Arima(co2, order = c(1,1,1),
seasonal = list(order = c(0,1,1), period = 12),
method = "CSS-ML")
prev_sarima <- forecast(fit_sarima, h = h, level = 95)
prev_sar_df <- tibble(
tempo = t_prev, modelo = "SARIMA(1,1,1)(0,1,1)[12]",
central = as.numeric(prev_sarima$mean),
lo95    = as.numeric(prev_sarima$lower[, 1]),
hi95    = as.numeric(prev_sarima$upper[, 1])
)
# Consolidado para plots
prev_all <- bind_rows(prev_A_df, prev_df, prev_C_df, prev_sar_df)
# SĂ­ntese para texto
prev_dez98_mld    <- round(prev_df$central[12], 2)
prev_dez99_mld    <- round(prev_df$central[24], 2)
ic95_lo_dez99_mld <- round(prev_df$lo95[24], 2)
ic95_hi_dez99_mld <- round(prev_df$hi95[24], 2)
prev_dez98_sar    <- round(prev_sar_df$central[12], 2)
prev_dez99_sar    <- round(prev_sar_df$central[24], 2)
larg_ic_h1        <- round(prev_df$hi95[1]  - prev_df$lo95[1],  2)
larg_ic_h24       <- round(prev_df$hi95[24] - prev_df$lo95[24], 2)
#| label: plot-previsao
#| fig-cap: "PrevisĂµes dos trĂŞs MLDs e do SARIMA$(1,1,1)(0,1,1)_{12}$ para 1998â€“1999 com IC 95%. A sĂ©rie observada de 1993 a 1997 Ă© exibida Ă  esquerda da linha de corte."
#| fig-height: 6
obs_recente <- co2_df |> filter(ano >= 1993)
cores_mod <- c(
"A â€” dlmModSeas"           = cores[2],
"B â€” dlmModTrig"           = cores[3],
"C â€” KFAS"                 = cores[5],
"SARIMA(1,1,1)(0,1,1)[12]"  = cores[4]
)
ggplot() +
geom_line(data = obs_recente,
aes(x = tempo, y = ppm),
color = cores[1], linewidth = 0.8) +
geom_ribbon(data = prev_all,
aes(x = tempo, ymin = lo95, ymax = hi95, fill = modelo),
alpha = 0.12) +
geom_line(data = prev_all,
aes(x = tempo, y = central, color = modelo),
linewidth = 0.85) +
geom_vline(xintercept = 1998,
linetype = "dashed", color = "gray40", linewidth = 0.7) +
annotate("text", x = 1997.65, y = 358,
label = "Fim obs.", angle = 90, size = 3, color = "gray40") +
scale_color_manual(values = cores_mod) +
scale_fill_manual(values  = cores_mod) +
scale_x_continuous(breaks = seq(1993, 2000, by = 1)) +
scale_y_continuous(labels = label_number(suffix = " ppm")) +
labs(
