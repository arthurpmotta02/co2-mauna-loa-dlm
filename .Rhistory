)
prev_tab |>
gt(groupname_col = "Ano") |>
tab_header(
title    = md("**Tabela 2.** PrevisĂµes Selecionadas â€” TrĂŞs MLDs e SARIMA (ppm)"),
subtitle = "Meses de marĂ§o, junho, setembro e dezembro de 1998 e 1999. IC 95%."
) |>
tab_spanner(label = "Mod. A (dlmModSeas)", columns = starts_with("Mod. A")) |>
tab_spanner(label = "Mod. B (dlmModTrig)", columns = starts_with("Mod. B")) |>
tab_spanner(label = "Mod. C (KFAS)",       columns = starts_with("Mod. C")) |>
tab_spanner(label = "SARIMA(1,1,1)(0,1,1)[12]", columns = starts_with("SARIMA")) |>
cols_label(
Mes               = "MĂŞs",
`Mod. A_central`  = "Prev.",
`Mod. A_lo95`     = "IC inf",
`Mod. A_hi95`     = "IC sup",
`Mod. B_central`  = "Prev.",
`Mod. B_lo95`     = "IC inf",
`Mod. B_hi95`     = "IC sup",
`Mod. C_central`  = "Prev.",
`Mod. C_lo95`     = "IC inf",
`Mod. C_hi95`     = "IC sup",
`SARIMA_central`  = "Prev.",
`SARIMA_lo95`     = "IC inf",
`SARIMA_hi95`     = "IC sup"
) |>
fmt_number(where(is.numeric), decimals = 2) |>
tab_style(style = cell_fill(color = "#f0f7ff"),
locations = cells_row_groups()) |>
tab_style(style = cell_fill(color = "#e8f4f8"),
locations = cells_body(columns = starts_with("Mod. B")))
#| label: diagnostico-todos
#| fig-cap: "InovaĂ§Ăµes $e_t = y_t - f_t$ dos trĂŞs modelos ao longo do tempo. Linhas pontilhadas: $\\pm 2$ desvios padrĂŁo. InovaĂ§Ăµes sem padrĂŁo sistemĂˇtico e com variĂ˘ncia constante indicam adequaĂ§ĂŁo do modelo (pressuposto P1 e P2)."
#| fig-height: 8
# INOVAĂ‡Ă•ES BRUTAS: e_t = y_t - f_t (em ppm)
# No dlm, residuals(filt, sd=FALSE) retorna PADRONIZADAS e_t/sqrt(Q_t).
# As inovaĂ§Ăµes brutas sĂŁo obtidas diretamente de filt$f (previsĂŁo 1-passo):
y_vec    <- as.numeric(co2)
et_bruto <- y_vec - filt$f    # Modelo B: e_t bruto (ppm)
filt_A   <- dlmFilter(y_vec, mld_A)
et_A     <- y_vec - filt_A$f  # Modelo A: e_t bruto (ppm)
# Modelo C (KFAS): residuals(type="recursive") retorna os erros de previsĂŁo
# 1-passo normalizados pelo KFAS internamente â€” dividir pelo desvio padrĂŁo
# para obter os erros padronizados, OU usar diretamente se jĂˇ estiverem em ppm.
# O objeto retornado tem a mesma unidade de y_t (ppm).
# NAs no inĂ­cio correspondem ao perĂ­odo difuso e sĂŁo descartados pelo na.omit.
et_C_raw <- as.numeric(residuals(kfas_full, type = "recursive"))
et_C     <- et_C_raw
# Mascarar outliers do perĂ­odo difuso do KFAS:
# valores com |e_t| > 5x o desvio padrĂŁo robusto apĂłs o burnin
sd_robust_C      <- mad(na.omit(et_C)[(burnin+1):length(na.omit(et_C))])
et_C[abs(et_C) > 5 * sd_robust_C] <- NA
# DiagnĂłstico de escala apĂłs na.omit (descarta perĂ­odo difuso)
cat(sprintf("Modelo A â€” sd(et): %.4f ppm\n", sd(na.omit(et_A), na.rm = TRUE)))
cat(sprintf("Modelo B â€” sd(et): %.4f ppm\n", sd(na.omit(et_bruto), na.rm = TRUE)))
cat(sprintf("Modelo C â€” sd(et, sem difuso): %.4f ppm\n", sd(na.omit(et_C), na.rm = TRUE)))
# Armazenar para uso posterior
et_vals  <- na.omit(et_bruto)
burnin   <- 24L
et_conv  <- et_vals[(burnin + 1):length(et_vals)]
# Para Modelo C: remover NAs (perĂ­odo difuso) E aplicar o mesmo burn-in
et_A_conv <- na.omit(et_A)[(burnin + 1):length(na.omit(et_A))]
et_C_conv <- na.omit(et_C)[(burnin + 1):length(na.omit(et_C))]
make_inovacao_plot <- function(et, titulo, cor) {
et_clean <- na.omit(et)
# Limites do eixo Y baseados nos dados limpos (sem outliers difusos)
ylim_val <- max(abs(et_clean)) * 1.05
tibble(tempo = tempo_vec[seq_along(et)], et = et) |>
ggplot(aes(x = tempo, y = et)) +
geom_line(color = cor, linewidth = 0.45, alpha = 0.8, na.rm = TRUE) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50") +
geom_hline(yintercept = c(-2, 2) * sd(et_clean),
linetype = "dotted", color = cores[2], linewidth = 0.5) +
coord_cartesian(ylim = c(-ylim_val, ylim_val)) +
scale_x_continuous(breaks = seq(1960, 1997, by = 5)) +
labs(title = titulo, x = NULL,
y = expression(e[t] ~ "(ppm)"))
}
p_A <- make_inovacao_plot(et_A,     "Modelo A â€” dlmModSeas",   cores[1])
p_B <- make_inovacao_plot(et_bruto, "Modelo B â€” dlmModTrig",   cores[2])
p_C <- make_inovacao_plot(et_C,     "Modelo C â€” KFAS",         cores[3])
p_A / p_B / p_C
#| label: diagnostico-acf-todos
#| fig-cap: "ACF das inovaĂ§Ăµes dos trĂŞs modelos (apĂłs burn-in de `r burnin` meses). Barras fora das bandas $\\pm 1{,}96/\\sqrt{n}$ indicam autocorrelaĂ§ĂŁo residual (violaĂ§ĂŁo de P2)."
#| fig-height: 7
make_acf_plot <- function(et_c, titulo, cor) {
n_c  <- length(et_c)
ic   <- 1.96 / sqrt(n_c)
obj  <- acf(et_c, lag.max = 36, plot = FALSE)
tibble(lag = as.integer(obj$lag[-1]), acf = as.numeric(obj$acf[-1])) |>
ggplot(aes(x = lag, y = acf)) +
geom_hline(yintercept = 0, color = "gray50") +
geom_segment(aes(xend = lag, yend = 0), color = cor, linewidth = 0.7) +
geom_hline(yintercept = c(-ic, ic), linetype = "dashed",
color = cores[2], linewidth = 0.7) +
scale_x_continuous(breaks = seq(0, 36, by = 6)) +
labs(title = titulo, x = "Defasagem", y = "ACF")
}
p_acf_A <- make_acf_plot(et_A_conv, "ACF â€” Modelo A (dlmModSeas)", cores[1])
p_acf_B <- make_acf_plot(et_conv,   "ACF â€” Modelo B (dlmModTrig)", cores[2])
p_acf_C <- make_acf_plot(et_C_conv, "ACF â€” Modelo C (KFAS)",       cores[3])
p_acf_A / p_acf_B / p_acf_C
#| label: diagnostico-normalidade
#| fig-cap: "Q-Q plots das inovaĂ§Ăµes dos trĂŞs modelos (apĂłs burn-in). Alinhamento com a reta indica normalidade (pressuposto P3). Histogramas com curva normal sobreposta."
#| fig-height: 8
make_qq_plot <- function(et_c, titulo, cor) {
tibble(e = et_c) |>
ggplot(aes(sample = e)) +
stat_qq(color = cor, alpha = 0.5, size = 0.8) +
stat_qq_line(color = cores[2], linewidth = 0.9) +
labs(title = titulo, x = "Quantis teĂłricos", y = "Quantis amostrais")
}
make_hist_plot <- function(et_c, cor) {
tibble(e = et_c) |>
ggplot(aes(x = e)) +
geom_histogram(aes(y = after_stat(density)), bins = 25,
fill = cor, color = "white", alpha = 0.75) +
stat_function(fun = dnorm,
args = list(mean = mean(et_c), sd = sd(et_c)),
color = cores[2], linewidth = 1.0) +
labs(x = expression(e[t]), y = "Densidade")
}
(make_qq_plot(et_A_conv, "Q-Q â€” Modelo A", cores[1]) |
make_hist_plot(et_A_conv, cores[1])) /
(make_qq_plot(et_conv,   "Q-Q â€” Modelo B", cores[2]) |
make_hist_plot(et_conv,   cores[2])) /
(make_qq_plot(et_C_conv, "Q-Q â€” Modelo C", cores[3]) |
make_hist_plot(et_C_conv, cores[3]))
#| label: diagnostico-testes
#| code-summary: "Testes formais â€” Modelo B (principal)"
sw   <- shapiro.test(et_conv)
lb6  <- Box.test(et_conv, lag = 6,  type = "Ljung-Box")
lb12 <- Box.test(et_conv, lag = 12, type = "Ljung-Box")
lb24 <- Box.test(et_conv, lag = 24, type = "Ljung-Box")
tibble(
Teste       = c("Shapiro-Wilk",
"Ljung-Box ($h = 6$)",
"Ljung-Box ($h = 12$)",
"Ljung-Box ($h = 24$)"),
Pressuposto = c("P3 â€” Normalidade", "P2 â€” RuĂ­do branco",
"P2 â€” RuĂ­do branco", "P2 â€” RuĂ­do branco"),
Estatistica = round(c(sw$statistic, lb6$statistic,
lb12$statistic, lb24$statistic), 4),
p_valor     = round(c(sw$p.value, lb6$p.value,
lb12$p.value, lb24$p.value), 4),
Conclusao   = c(
ifelse(sw$p.value   > 0.05, "NĂŁo rejeita $H_0$", "Rejeita $H_0$"),
ifelse(lb6$p.value  > 0.05, "NĂŁo rejeita $H_0$", "Rejeita $H_0$"),
ifelse(lb12$p.value > 0.05, "NĂŁo rejeita $H_0$", "Rejeita $H_0$"),
ifelse(lb24$p.value > 0.05, "NĂŁo rejeita $H_0$", "Rejeita $H_0$")
)
) |>
gt() |>
fmt_markdown(columns = c(Teste, Conclusao)) |>
tab_header(
title    = md("**Tabela 3.** Testes Formais sobre as InovaĂ§Ăµes â€” Modelo B"),
subtitle = md(sprintf("$e_t$, $t = %d, \\ldots, n$ (descartados primeiros %d meses de burn-in)",
burnin + 1, burnin))
) |>
fmt_number(columns = c(Estatistica, p_valor), decimals = 4) |>
cols_label(Pressuposto = "Pressuposto", Estatistica = "EstatĂ­stica",
p_valor = md("$p$-valor"), Conclusao = "ConclusĂŁo") |>
tab_style(style = cell_fill(color = "#fce4e4"),
locations = cells_body(rows = p_valor < 0.05)) |>
tab_style(style = cell_fill(color = "#e8f4f8"),
locations = cells_body(rows = p_valor >= 0.05))
#| label: diagnostico-comparativo
#| code-summary: "DiagnĂłstico comparativo â€” Modelos A, B e C"
sw_A <- shapiro.test(et_A_conv)
sw_C <- shapiro.test(et_C_conv)
lb_A <- Box.test(et_A_conv, lag = 12, type = "Ljung-Box")
lb_B <- Box.test(et_conv,   lag = 12, type = "Ljung-Box")
lb_C <- Box.test(et_C_conv, lag = 12, type = "Ljung-Box")
tibble(
Modelo  = c("A â€” dlmModSeas", "B â€” dlmModTrig", "C â€” KFAS"),
LogLik  = round(c(ll_A, ll_B, as.numeric(ll_C)), 2),
RMSE    = round(c(sqrt(mean(et_A_conv^2)),
sqrt(mean(et_conv^2)),
sqrt(mean(et_C_conv^2))), 4),
LB_p    = round(c(lb_A$p.value, lb_B$p.value, lb_C$p.value), 4),
SW_p    = round(c(sw_A$p.value, sw$p.value,   sw_C$p.value), 4),
P2_ok   = c(lb_A$p.value > 0.05, lb_B$p.value > 0.05, lb_C$p.value > 0.05),
P3_ok   = c(sw_A$p.value > 0.05, sw$p.value  > 0.05,  sw_C$p.value > 0.05)
) |>
gt() |>
tab_header(
title    = md("**Tabela 4.** DiagnĂłstico Comparativo dos TrĂŞs Modelos"),
subtitle = md(sprintf("InovaĂ§Ăµes $e_t$, $t = %d, \\ldots, n$ (burn-in = %d meses)",
burnin + 1, burnin))
) |>
fmt_number(columns = LogLik, decimals = 2) |>
fmt_number(columns = RMSE,   decimals = 4) |>
fmt_number(columns = c(LB_p, SW_p), decimals = 4) |>
cols_label(
Modelo = "Modelo",
LogLik = md("$\\ell(\\hat{\\theta})$"),
RMSE   = md("RMSE$(e_t)$"),
LB_p   = md("LB $p$-valor ($h=12$)"),
SW_p   = md("SW $p$-valor"),
P2_ok  = "P2 ok?",
P3_ok  = "P3 ok?"
) |>
tab_footnote(
footnote  = md("RMSE$(e_t) = \\sqrt{n^{-1}\\sum_{t=t_0}^n e_t^2}$ â€” mede dispersĂŁo das inovaĂ§Ăµes (pressuposto P1)."),
locations = cells_column_labels(columns = RMSE)
) |>
tab_style(style = cell_fill(color = "#e8f4f8"),
locations = cells_body(rows = P2_ok == TRUE & P3_ok == TRUE)) |>
tab_style(style = cell_fill(color = "#fce4e4"),
locations = cells_body(rows = P2_ok == FALSE))
#| label: session-info
#| code-summary: "InformaĂ§Ăµes da sessĂŁo R"
sessionInfo()
