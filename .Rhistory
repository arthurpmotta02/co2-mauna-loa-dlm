"SARIMA(1,1,1)(0,1,1)[12]" = "SARIMA"
)
) |>
filter(Mes %in% c("MarĂ§o","Junho","Setembro","Dezembro")) |>
select(Ano, Mes, mod_s, central, lo95, hi95) |>
pivot_wider(
names_from  = mod_s,
values_from = c(central, lo95, hi95),
